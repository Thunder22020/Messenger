# Copy this file to .env and fill in the values.
# .env is gitignored and never committed.
#
# Spring Boot does NOT load .env automatically.
# Set these variables in your shell, IDE run config, or docker-compose.yml.

# PostgreSQL credentials
DB_USERNAME=postgres
DB_PASSWORD=your_db_password

# JWT signing secret — must be at least 256 bits (64 hex characters).
# Generate one with: openssl rand -hex 32
JWT_SECRET=replace_with_64_hex_chars
