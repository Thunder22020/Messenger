# Copy this file to .env and fill in the values.
# .env is gitignored and never committed.
#
# Spring Boot does NOT load .env automatically.
# Set these variables in your shell, IDE run config, or docker-compose.yml.

# PostgreSQL
DB_USERNAME=postgres
DB_PASSWORD=change_me_strong_password

# JWT signing secret. Generate with: openssl rand -base64 48
JWT_SECRET=change_me_generated_jwt_secret

# JPA
JPA_DDL_AUTO=validate

# CORS / cookies
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
APP_COOKIE_SECURE=false

# TURN. Generate secret with: openssl rand -base64 32
TURN_SECRET=change_me_generated_turn_secret
TURN_URL=turn.example.com

# S3-compatible storage
S3_ACCESS_KEY=change_me_s3_access_key
S3_SECRET_KEY=change_me_s3_secret_key
S3_REGION=us-east-1
S3_ENDPOINT=https://your-s3-endpoint
S3_BUCKET=your-bucket-name
S3_FETCH_URL=https://your-public-s3-url

# Web Push / VAPID. Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=change_me_vapid_public_key
VAPID_PRIVATE_KEY=change_me_vapid_private_key
VAPID_SUBJECT=mailto:admin@example.com
