# Copy to .env and fill in all values before running docker-compose

# ── Domain ────────────────────────────────────────────────────────────────────
# Frontend origin — used for CORS
APP_CORS_ALLOWED_ORIGINS=http://synk.su,http://www.synk.su

# Frontend build — baked into the React bundle at build time
VITE_API_URL=http://api.synk.su
VITE_WS_URL=ws://api.synk.su

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_USERNAME=messenger
DB_PASSWORD=your_strong_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=your_jwt_secret_here

# ── JPA DDL ───────────────────────────────────────────────────────────────────
# Use 'update' on first deploy (creates tables), then change to 'validate'
JPA_DDL_AUTO=update

# ── S3-compatible storage ─────────────────────────────────────────────────────
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_REGION=ru-7
S3_ENDPOINT=https://your-s3-endpoint
S3_BUCKET=your-bucket-name
S3_FETCH_URL=https://your-public-s3-url
