# Copy to .env and fill in all values before running docker-compose.
# Do not commit real .env files.

# ── Domain ────────────────────────────────────────────────────────────────────
# Frontend origins used for CORS. Separate multiple origins with commas.
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Frontend build — baked into the React bundle at build time
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_USERNAME=messenger
DB_PASSWORD=change_me_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=change_me_generated_jwt_secret

# ── JPA DDL ───────────────────────────────────────────────────────────────────
# Use 'update' on first deploy (creates tables), then change to 'validate'
JPA_DDL_AUTO=update

# ── Cookies ───────────────────────────────────────────────────────────────────
# Use true behind HTTPS; false is useful for local HTTP development.
APP_COOKIE_SECURE=false

# ── TURN (WebRTC relay for users behind strict NATs) ──────────────────────────
# Generate with: openssl rand -base64 32
TURN_SECRET=change_me_generated_turn_secret
TURN_URL=turn.example.com

# ── S3-compatible storage ─────────────────────────────────────────────────────
S3_ACCESS_KEY=change_me_s3_access_key
S3_SECRET_KEY=change_me_s3_secret_key
S3_REGION=us-east-1
S3_ENDPOINT=https://your-s3-endpoint
S3_BUCKET=your-bucket-name
S3_FETCH_URL=https://your-public-s3-url

# ── Web Push / VAPID ──────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=change_me_vapid_public_key
VAPID_PRIVATE_KEY=change_me_vapid_private_key
VAPID_SUBJECT=mailto:admin@example.com
VITE_VAPID_PUBLIC_KEY=change_me_vapid_public_key

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_grafana_password
